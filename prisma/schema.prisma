generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  ADMINISTRADOR
  COLABORADOR
  CLIENTE
}

enum CompanyType {
  AGENCIA
  EMPRESA
}

enum PlanType {
  BOLSA_HORAS
  SOPORTE_MENSUAL
}

enum TicketStatus {
  ABIERTO
  EN_PROGRESO
  EN_REVISION
  CERRADO
}

enum Priority {
  BAJA
  MEDIA
  ALTA
  CRITICA
}

// ─── Models ──────────────────────────────────────────────────────────────────

model Company {
  id               String      @id @default(cuid())
  name             String
  type             CompanyType @default(EMPRESA) @map("type")
  taxId            String?     @map("tax_id")
  logoUrl          String?     @map("logo_url")
  logoStoragePath  String?     @map("logo_storage_path")
  isActive         Boolean     @default(true) @map("is_active")
  createdAt        DateTime    @default(now()) @map("created_at")
  updatedAt        DateTime    @updatedAt @map("updated_at")

  parentId         String?     @map("parent_id")
  parent           Company?    @relation("AgencySubCompanies", fields: [parentId], references: [id])
  subCompanies     Company[]   @relation("AgencySubCompanies")

  users            User[]
  plans            Plan[]

  @@map("companies")
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         Role     @default(CLIENTE)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  companies    Company[]

  createdTickets   Ticket[]             @relation("CreatedBy")
  assignedTickets  Ticket[]             @relation("AssignedTo")
  clientTickets    Ticket[]             @relation("TicketClient")
  comments         TicketComment[]
  attachments      TicketAttachment[]
  resetTokens      PasswordResetToken[]
  timeEntries      TimeEntry[]

  @@map("users")
}

model Ticket {
  id           String       @id @default(cuid())
  title        String
  description  String
  status       TicketStatus @default(ABIERTO)
  priority     Priority     @default(MEDIA)
  category     String?

  createdById  String   @map("created_by_id")
  assignedToId String?  @map("assigned_to_id")
  clientId     String?  @map("client_id")
  planId       String?  @map("plan_id")

  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  createdBy    User               @relation("CreatedBy", fields: [createdById], references: [id])
  assignedTo   User?              @relation("AssignedTo", fields: [assignedToId], references: [id])
  client       User?              @relation("TicketClient", fields: [clientId], references: [id])
  plan         Plan?              @relation(fields: [planId], references: [id])
  comments     TicketComment[]
  attachments  TicketAttachment[]
  timeEntries  TimeEntry[]

  @@map("tickets")
}

model Plan {
  id           String    @id @default(cuid())
  name         String
  type         PlanType
  totalHours   Float?    @map("total_hours")
  durationDays Int?      @map("duration_days")
  startedAt    DateTime  @default(now()) @map("started_at")
  expiresAt    DateTime? @map("expires_at")
  isActive     Boolean   @default(true) @map("is_active")

  companyId    String    @map("company_id")
  company      Company   @relation(fields: [companyId], references: [id])

  tickets      Ticket[]

  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@map("plans")
}

model TicketComment {
  id         String   @id @default(cuid())
  body       String
  isInternal Boolean  @default(false) @map("is_internal")

  ticketId   String   @map("ticket_id")
  authorId   String   @map("author_id")

  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  ticket     Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author     User     @relation(fields: [authorId], references: [id])

  @@map("ticket_comments")
}

model TicketAttachment {
  id           String   @id @default(cuid())
  fileUrl      String   @map("file_url")
  fileName     String   @map("file_name")
  storagePath  String   @map("storage_path")

  ticketId     String   @map("ticket_id")
  uploadedById String   @map("uploaded_by_id")

  createdAt    DateTime @default(now()) @map("created_at")

  ticket       Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  uploadedBy   User     @relation(fields: [uploadedById], references: [id])

  @@map("ticket_attachments")
}

model TimeEntry {
  id         String    @id @default(cuid())
  startedAt  DateTime  @map("started_at")
  stoppedAt  DateTime? @map("stopped_at")

  ticketId   String    @map("ticket_id")
  userId     String    @map("user_id")

  ticket     Ticket    @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user       User      @relation(fields: [userId], references: [id])

  @@map("time_entries")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

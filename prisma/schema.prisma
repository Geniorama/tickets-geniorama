generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  ADMINISTRADOR
  COLABORADOR
  CLIENTE
}

enum CompanyType {
  AGENCIA
  EMPRESA
}

enum PlanType {
  BOLSA_HORAS
  SOPORTE_MENSUAL
}

enum TicketStatus {
  ABIERTO
  EN_PROGRESO
  EN_REVISION
  CERRADO
}

enum Priority {
  BAJA
  MEDIA
  ALTA
  CRITICA
}

enum ProjectStatus {
  PLANIFICACION
  EN_DESARROLLO
  EN_REVISION
  COMPLETADO
  PAUSADO
}

enum TaskStatus {
  PENDIENTE
  EN_PROGRESO
  EN_REVISION
  COMPLETADO
}

enum ServiceType {
  DOMINIO
  HOSTING
  CORREO
  SSL
  MANTENIMIENTO
  OTRO
}

enum ServiceProvider {
  GENIORAMA
  EXTERNO
}

// ─── Models ──────────────────────────────────────────────────────────────────

model Company {
  id               String      @id @default(cuid())
  name             String
  type             CompanyType @default(EMPRESA) @map("type")
  taxId            String?     @map("tax_id")
  logoUrl          String?     @map("logo_url")
  logoStoragePath  String?     @map("logo_storage_path")
  isActive         Boolean     @default(true) @map("is_active")
  createdAt        DateTime    @default(now()) @map("created_at")
  updatedAt        DateTime    @updatedAt @map("updated_at")

  parentId         String?     @map("parent_id")
  parent           Company?    @relation("AgencySubCompanies", fields: [parentId], references: [id])
  subCompanies     Company[]   @relation("AgencySubCompanies")

  users            User[]
  plans            Plan[]
  projects         Project[]
  services         Service[]
  sites            Site[]
  vaultEntries     VaultEntry[]

  @@map("companies")
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         Role     @default(CLIENTE)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  companies    Company[]

  createdTickets   Ticket[]             @relation("CreatedBy")
  assignedTickets  Ticket[]             @relation("AssignedTo")
  clientTickets    Ticket[]             @relation("TicketClient")
  comments         TicketComment[]
  attachments      TicketAttachment[]
  resetTokens      PasswordResetToken[]
  timeEntries      TimeEntry[]

  managedProjects  Project[]            @relation("ProjectManager")
  createdProjects  Project[]            @relation("ProjectCreatedBy")
  assignedTasks    Task[]               @relation("TaskAssignedTo")
  createdTasks     Task[]               @relation("TaskCreatedBy")
  taskComments     TaskComment[]
  taskAttachments  TaskAttachment[]
  createdServices  Service[]            @relation("ServiceCreatedBy")
  taskTimeEntries  TaskTimeEntry[]

  createdVaultEntries VaultEntry[]      @relation("VaultCreatedBy")
  vaultShares         VaultShare[]      @relation("VaultSharedWith")
  projectAttachments  ProjectAttachment[]
  notifications       Notification[]

  @@map("users")
}

model Ticket {
  id           String       @id @default(cuid())
  title        String
  description  String
  status       TicketStatus @default(ABIERTO)
  priority     Priority     @default(MEDIA)
  category     String?

  createdById  String   @map("created_by_id")
  assignedToId String?  @map("assigned_to_id")
  clientId     String?  @map("client_id")
  planId       String?  @map("plan_id")
  siteId       String?  @map("site_id")

  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  createdBy    User               @relation("CreatedBy", fields: [createdById], references: [id])
  assignedTo   User?              @relation("AssignedTo", fields: [assignedToId], references: [id])
  client       User?              @relation("TicketClient", fields: [clientId], references: [id])
  plan         Plan?              @relation(fields: [planId], references: [id])
  site         Site?              @relation(fields: [siteId], references: [id])
  comments     TicketComment[]
  attachments  TicketAttachment[]
  timeEntries  TimeEntry[]

  @@map("tickets")
}

model Plan {
  id           String    @id @default(cuid())
  name         String
  type         PlanType
  totalHours   Float?    @map("total_hours")
  durationDays Int?      @map("duration_days")
  startedAt    DateTime  @default(now()) @map("started_at")
  expiresAt    DateTime? @map("expires_at")
  isActive     Boolean   @default(true) @map("is_active")

  companyId    String    @map("company_id")
  company      Company   @relation(fields: [companyId], references: [id])

  tickets      Ticket[]

  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@map("plans")
}

model TicketComment {
  id         String   @id @default(cuid())
  body       String
  isInternal Boolean  @default(false) @map("is_internal")

  // Adjunto opcional (link externo o archivo)
  attachmentType        String? @map("attachment_type")         // "link" | "file"
  attachmentUrl         String? @map("attachment_url")
  attachmentName        String? @map("attachment_name")
  attachmentStoragePath String? @map("attachment_storage_path") // solo archivos Supabase

  ticketId   String   @map("ticket_id")
  authorId   String   @map("author_id")

  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  ticket     Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author     User     @relation(fields: [authorId], references: [id])

  @@map("ticket_comments")
}

model TicketAttachment {
  id           String   @id @default(cuid())
  fileUrl      String   @map("file_url")
  fileName     String   @map("file_name")
  storagePath  String   @map("storage_path")

  ticketId     String   @map("ticket_id")
  uploadedById String   @map("uploaded_by_id")

  createdAt    DateTime @default(now()) @map("created_at")

  ticket       Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  uploadedBy   User     @relation(fields: [uploadedById], references: [id])

  @@map("ticket_attachments")
}

model TimeEntry {
  id         String    @id @default(cuid())
  startedAt  DateTime  @map("started_at")
  stoppedAt  DateTime? @map("stopped_at")

  ticketId   String    @map("ticket_id")
  userId     String    @map("user_id")

  ticket     Ticket    @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user       User      @relation(fields: [userId], references: [id])

  @@map("time_entries")
}

model TaskTimeEntry {
  id        String    @id @default(cuid())
  startedAt DateTime  @map("started_at")
  stoppedAt DateTime? @map("stopped_at")

  taskId    String    @map("task_id")
  userId    String    @map("user_id")

  task      Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id])

  @@map("task_time_entries")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

model Project {
  id          String        @id @default(cuid())
  name        String
  description String        @db.Text
  status      ProjectStatus @default(PLANIFICACION)
  isActive    Boolean       @default(true) @map("is_active")
  startDate   DateTime?     @map("start_date")
  dueDate     DateTime?     @map("due_date")

  companyId   String?       @map("company_id")
  managerId   String?       @map("manager_id")
  createdById String        @map("created_by_id")

  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  company      Company?            @relation(fields: [companyId], references: [id])
  manager      User?               @relation("ProjectManager", fields: [managerId], references: [id])
  createdBy    User                @relation("ProjectCreatedBy", fields: [createdById], references: [id])
  tasks        Task[]
  vaultEntries ProjectVaultEntry[]
  attachments  ProjectAttachment[]

  @@map("projects")
}

model ProjectAttachment {
  id           String   @id @default(cuid())
  type         String   @default("file")     // "file" | "link"
  fileUrl      String   @map("file_url")     // URL para files o la URL del enlace
  fileName     String   @map("file_name")    // Nombre a mostrar
  storagePath  String?  @map("storage_path") // Solo para archivos en R2

  position     Int      @default(0)

  projectId    String   @map("project_id")
  uploadedById String   @map("uploaded_by_id")

  createdAt    DateTime @default(now()) @map("created_at")

  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  uploadedBy   User     @relation(fields: [uploadedById], references: [id])

  @@map("project_attachments")
}

model ProjectVaultEntry {
  projectId    String     @map("project_id")
  vaultEntryId String     @map("vault_entry_id")

  project      Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  vaultEntry   VaultEntry @relation(fields: [vaultEntryId], references: [id], onDelete: Cascade)

  addedAt      DateTime   @default(now()) @map("added_at")

  @@id([projectId, vaultEntryId])
  @@map("project_vault_entries")
}

model Task {
  id             String     @id @default(cuid())
  title          String
  description    String
  status         TaskStatus @default(PENDIENTE)
  priority       Priority   @default(MEDIA)
  category       String?

  startDate      DateTime?  @map("start_date")
  dueDate        DateTime?  @map("due_date")
  estimatedHours Float?     @map("estimated_hours")

  projectId    String  @map("project_id")
  assignedToId String? @map("assigned_to_id")
  createdById  String  @map("created_by_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  project    Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignedTo User?         @relation("TaskAssignedTo", fields: [assignedToId], references: [id])
  createdBy  User          @relation("TaskCreatedBy", fields: [createdById], references: [id])
  comments    TaskComment[]
  attachments TaskAttachment[]
  timeEntries TaskTimeEntry[]

  @@map("tasks")
}

model TaskComment {
  id                    String   @id @default(cuid())
  body                  String
  attachmentType        String?  @map("attachment_type")
  attachmentUrl         String?  @map("attachment_url")
  attachmentName        String?  @map("attachment_name")
  attachmentStoragePath String?  @map("attachment_storage_path")

  taskId   String @map("task_id")
  authorId String @map("author_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  task   Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id])

  @@map("task_comments")
}

model TaskAttachment {
  id           String   @id @default(cuid())
  fileUrl      String   @map("file_url")
  fileName     String   @map("file_name")
  storagePath  String   @map("storage_path")

  taskId       String @map("task_id")
  uploadedById String @map("uploaded_by_id")

  createdAt DateTime @default(now()) @map("created_at")

  task       Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  uploadedBy User @relation(fields: [uploadedById], references: [id])

  @@map("task_attachments")
}

model Service {
  id          String          @id @default(cuid())
  name        String
  type        ServiceType
  provider    ServiceProvider @default(GENIORAMA)
  description String?
  dueDate     DateTime?       @map("due_date")
  price       Float?
  notes       String?
  isActive    Boolean         @default(true) @map("is_active")

  companyId   String          @map("company_id")
  createdById String          @map("created_by_id")

  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  company      Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy    User            @relation("ServiceCreatedBy", fields: [createdById], references: [id])
  vaultEntries VaultEntry[]

  @@map("services")
}

// ─── Bóveda ──────────────────────────────────────────────────────────────────

model VaultEntry {
  id          String   @id @default(cuid())
  title       String
  username    String?
  password    String   // AES-256-GCM cifrado: "<iv_hex>:<tag_hex>:<cipher_hex>"
  url         String?
  notes       String?  @db.Text

  companyId   String?  @map("company_id")
  siteId      String?  @map("site_id")
  serviceId   String?  @map("service_id")
  createdById String   @map("created_by_id")

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  company     Company?   @relation(fields: [companyId], references: [id])
  site        Site?      @relation(fields: [siteId], references: [id])
  service     Service?   @relation(fields: [serviceId], references: [id])
  createdBy   User       @relation("VaultCreatedBy", fields: [createdById], references: [id])
  sharedWith  VaultShare[]
  projects    ProjectVaultEntry[]

  @@map("vault_entries")
}

model VaultShare {
  id           String     @id @default(cuid())
  vaultEntryId String     @map("vault_entry_id")
  userId       String     @map("user_id")

  vaultEntry   VaultEntry @relation(fields: [vaultEntryId], references: [id], onDelete: Cascade)
  user         User       @relation("VaultSharedWith", fields: [userId], references: [id], onDelete: Cascade)

  createdAt    DateTime   @default(now()) @map("created_at")

  @@unique([vaultEntryId, userId])
  @@map("vault_shares")
}

model Site {
  id            String   @id @default(cuid())
  name          String
  domain        String
  documentation String?  @db.Text
  architecture  String?  @db.Text
  isActive      Boolean  @default(true) @map("is_active")

  companyId     String   @map("company_id")

  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  company      Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  tickets      Ticket[]
  vaultEntries VaultEntry[]

  @@map("sites")
}

model Notification {
  id        String    @id @default(cuid())
  type      String
  title     String
  message   String
  link      String?
  isRead    Boolean   @default(false) @map("is_read")
  readAt    DateTime? @map("read_at")

  userId    String    @map("user_id")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now()) @map("created_at")

  @@index([userId, createdAt(sort: Desc)])
  @@map("notifications")
}
